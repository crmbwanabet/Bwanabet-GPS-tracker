<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0A0A0F">

    <!-- Logo -->
    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/logo_bg"
        android:gravity="center"
        android:text="BW"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BwanaBet Tracker"
        android:textColor="#F5C518"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPS Location Tracking"
        android:textColor="#71717A"
        android:textSize="14sp"
        android:layout_marginBottom="48dp" />

    <!-- Tracking status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\u25cb Tracking Stopped"
        android:textColor="#EF4444"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Pending sync count -->
    <TextView
        android:id="@+id/pendingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All synced"
        android:textColor="#52525B"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- Device ID (selectable so user can copy) -->
    <TextView
        android:id="@+id/deviceIdText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device ID: ..."
        android:textColor="#71717A"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="48dp"
        android:textIsSelectable="true" />

    <!-- Start/Stop button -->
    <Button
        android:id="@+id/toggleBtn"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="Start Tracking"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#F5C518" />

    <!-- Instructions -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copy the Device ID above and\nregister it on the dashboard"
        android:textColor="#52525B"
        android:textSize="12sp"
        android:textAlignment="center"
        android:layout_marginTop="24dp" />

</LinearLayout>
